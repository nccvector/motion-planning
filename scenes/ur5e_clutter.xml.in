<mujoco model="ur5e_clutter">
  <include file="@UR5E_MODEL_XML@"/>

  <statistic center="-0.35 0 0.35" extent="1.1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.15 0.20 0.25 1"/>
    <global azimuth="125" elevation="-25"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.32 0.42 0.50" rgb2="0.02 0.03 0.04"
      width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.20 0.24 0.26"
      rgb2="0.10 0.12 0.13" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.15"/>
    <material name="shelf_mat" rgba="0.45 0.47 0.42 1"/>
    <material name="ring_mat" rgba="0.82 0.18 0.10 1"/>
    <material name="clutter_mat" rgba="0.18 0.50 0.64 1"/>
  </asset>

  <worldbody>
    <light pos="0 -1.0 1.8" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" contype="0" conaffinity="0"/>

    <body name="shelf_back" pos="-1.12 -0.18 0.40">
      <geom name="shelf_back_geom" type="box" size="0.025 0.63 0.30" material="shelf_mat"/>
    </body>
    <body name="shelf_left" pos="-0.92 -0.81 0.40">
      <geom name="shelf_left_geom" type="box" size="0.16 0.025 0.30" material="shelf_mat"/>
    </body>
    <body name="shelf_right" pos="-0.92 0.45 0.40">
      <geom name="shelf_right_geom" type="box" size="0.16 0.025 0.30" material="shelf_mat"/>
    </body>
    <body name="shelf_bottom" pos="-0.92 -0.18 0.035">
      <geom name="shelf_bottom_geom" type="box" size="0.16 0.63 0.015" material="shelf_mat"/>
    </body>
    <body name="shelf_top" pos="-0.92 -0.18 0.70">
      <geom name="shelf_top_geom" type="box" size="0.16 0.63 0.025" material="shelf_mat"/>
    </body>

    <body name="needle_ring" pos="-0.45 0 0.36">
      <geom name="ring_left_bar" type="box" pos="0 -0.27 0" size="0.035 0.035 0.205" material="ring_mat"/>
      <geom name="ring_right_bar" type="box" pos="0 0.27 0" size="0.035 0.035 0.205" material="ring_mat"/>
      <geom name="ring_top_bar" type="box" pos="0 0 0.205" size="0.035 0.305 0.035" material="ring_mat"/>
      <geom name="ring_bottom_bar" type="box" pos="0 0 -0.205" size="0.035 0.305 0.035" material="ring_mat"/>
    </body>

    <body name="ring_shelf_low_window" pos="-0.72 -0.18 0.25">
      <geom name="ring_shelf_low_left_bar" type="box" pos="0 -0.27 0" size="0.035 0.035 0.205" material="ring_mat"/>
      <geom name="ring_shelf_low_right_bar" type="box" pos="0 0.27 0" size="0.035 0.035 0.205" material="ring_mat"/>
      <geom name="ring_shelf_low_top_bar" type="box" pos="0 0 0.205" size="0.035 0.305 0.035" material="ring_mat"/>
      <geom name="ring_shelf_low_bottom_bar" type="box" pos="0 0 -0.205" size="0.035 0.305 0.035" material="ring_mat"/>
    </body>

    <body name="ring_shelf_high_window" pos="-0.72 -0.18 0.40">
      <geom name="ring_shelf_high_left_bar" type="box" pos="0 -0.27 0" size="0.035 0.035 0.205" material="ring_mat"/>
      <geom name="ring_shelf_high_right_bar" type="box" pos="0 0.27 0" size="0.035 0.035 0.205" material="ring_mat"/>
      <geom name="ring_shelf_high_top_bar" type="box" pos="0 0 0.205" size="0.035 0.305 0.035" material="ring_mat"/>
      <geom name="ring_shelf_high_bottom_bar" type="box" pos="0 0 -0.205" size="0.035 0.305 0.035" material="ring_mat"/>
    </body>

    <body name="ring_approach_left_post" pos="-0.28 0.32 0.23">
      <geom name="ring_approach_left_post_geom" type="box" size="0.035 0.035 0.22" material="clutter_mat"/>
    </body>
    <body name="ring_approach_right_post" pos="-0.28 -0.34 0.28">
      <geom name="ring_approach_right_post_geom" type="box" size="0.035 0.035 0.28" material="clutter_mat"/>
    </body>
    <body name="ring_approach_overhead" pos="-0.31 0.43 0.74">
      <geom name="ring_approach_overhead_geom" type="box" size="0.035 0.25 0.035" material="clutter_mat"/>
    </body>
    <body name="ring_exit_low_baffle" pos="-0.60 0.38 0.15">
      <geom name="ring_exit_low_baffle_geom" type="box" size="0.035 0.16 0.030" material="clutter_mat"/>
    </body>
    <body name="ring_exit_upper_baffle" pos="-0.61 -0.40 0.58">
      <geom name="ring_exit_upper_baffle_geom" type="box" size="0.035 0.28 0.035" material="clutter_mat"/>
    </body>

    <body name="shelf_entry_left_guard" pos="-0.69 -0.52 0.30">
      <geom name="shelf_entry_left_guard_geom" type="box" size="0.035 0.035 0.20" material="clutter_mat"/>
    </body>
    <body name="shelf_entry_right_guard" pos="-0.70 0.22 0.46">
      <geom name="shelf_entry_right_guard_geom" type="box" size="0.035 0.035 0.22" material="clutter_mat"/>
    </body>
    <body name="shelf_shallow_goal_blocker" pos="-0.585 -0.135 0.120">
      <geom name="shelf_shallow_goal_blocker_geom" type="box" size="0.028 0.055 0.045" material="clutter_mat"/>
    </body>
    <body name="shelf_mid_overhang" pos="-0.94 -0.02 0.56">
      <geom name="shelf_mid_overhang_geom" type="box" size="0.035 0.36 0.030" material="clutter_mat"/>
    </body>
    <body name="shelf_low_rail" pos="-0.88 0.08 0.24">
      <geom name="shelf_low_rail_geom" type="box" size="0.030 0.28 0.030" material="clutter_mat"/>
    </body>
  </worldbody>
</mujoco>
